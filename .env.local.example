# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — optional, only needed once email is wired
# RESEND_API_KEY=

# Site URL (used for OAuth redirects + OG meta)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Slack — incoming webhook URLs, one per channel. Optional; the Share dialog
# in admin hides Slack buttons whose webhook is unset.
# SLACK_WEBHOOK_EVENTS=
# SLACK_WEBHOOK_BLOG=
# SLACK_WEBHOOK_GENERAL=
