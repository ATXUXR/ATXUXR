# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — optional; needed for scheduling/publish emails to actually send
# RESEND_API_KEY=
# EMAIL_FROM="ATX UXR <hello@atxuxr.com>"

# Auto-publish scheduler (Netlify Scheduled Function -> /api/cron/publish-check)
# CRON_SECRET must match between Netlify env and the endpoint.
# CRON_SECRET=
# ADMIN_NOTIFY_EMAIL=          # where "published" notices go (defaults to first admin)
# CRON_PUBLISH_AUTHOR_ID=      # optional; author for auto-published posts (defaults to first admin)

# Site URL (used for OAuth redirects, OG meta, and email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Slack — incoming webhook URLs, one per channel. Optional.
# SLACK_WEBHOOK_EVENTS=
# SLACK_WEBHOOK_BLOG=
# SLACK_WEBHOOK_GENERAL=
